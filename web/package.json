{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite --host --force",
    "prebuild": "node scripts/download-python.js",
    "build": "vue-tsc -b && vite build && electron-builder",
    "build:mac": "vue-tsc -b && vite build && electron-builder --mac",
    "build:win": "vue-tsc -b && vite build && electron-builder --win",
    "build:all": "vue-tsc -b && vite build && electron-builder --mac --win",
    "preview": "vite preview --host"
  },
  "build": {
    "appId": "com.antigravity.workflow",
    "productName": "Agent Flow Platform",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "resources/python-env",
        "to": "python-env",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.1",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/multer": "^2.1.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.5.0",
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.5",
    "multer": "^2.1.1",
    "node-cron": "^4.3.0",
    "officeparser": "^7.2.1",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.15",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.12",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-vue": "^5.1.4",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "@noble/hashes": "^1.7.2"
    }
  }
}
